    // ════════════════════════════════════════
    // 가격/혜택 > 할인/쿠폰
    // ════════════════════════════════════════
    'CAT_7_1': [
      ['할인 행사 있나요?', '현재 정가 129,000원에서 31% 할인된 89,000원에 판매 중입니다.'],
      ['신규 회원 할인 있나요?', '회원가입 시 5,000원 할인 쿠폰이 자동 발급됩니다.'],
      ['2개 사면 추가 할인 있나요?', '2개 이상 구매 시 개당 5,000원 추가 할인됩니다.'],
      ['쿠폰 코드가 있나요?', 'SNS(인스타그램) 팔로우 시 3% 추가 할인 코드를 DM으로 보내드립니다.'],
      ['언제까지 할인하나요?', '현재 할인가는 재고 소진 시까지 적용됩니다.'],
      ['생일 쿠폰이 있나요?', '생일 달에 10% 할인 쿠폰이 자동 발급됩니다.'],
      ['쿠폰 중복 사용이 되나요?', '쿠폰은 1건당 1개만 적용 가능합니다. 적립금과 쿠폰은 동시 사용 가능합니다.'],
      ['블랙프라이데이 할인 있나요?', '연말 특별 할인 행사를 진행할 예정입니다. 알림 신청해주시면 안내드리겠습니다.']
    ],
    // ════════════════════════════════════════
    // 가격/혜택 > 결제/적립
    // ════════════════════════════════════════
    'CAT_7_2': [
      ['무이자 할부 되나요?', '삼성/신한/현대카드 3개월 무이자 할부 가능합니다.'],
      ['카카오페이로 결제 가능한가요?', '카카오페이, 네이버페이, 토스 모두 이용 가능합니다.'],
      ['적립금 사용 가능한가요?', '적립금 5,000원 이상부터 사용 가능하며, 결제 금액의 30%까지 적용 가능합니다.'],
      ['후불결제 되나요?', '네이버페이 나중에 결제, 카카오페이 후불 결제가 가능합니다.'],
      ['계좌이체도 가능한가요?', '무통장입금(가상계좌) 결제 가능하며, 입금 확인 후 출고됩니다.'],
      ['리뷰 적립금이 있나요?', '텍스트 리뷰 500원, 포토 리뷰 1,000원이 적립됩니다.'],
      ['적립금 유효기간이 있나요?', '적립일로부터 1년간 유효합니다.'],
      ['현금영수증 발급 되나요?', '네, 결제 시 현금영수증 발급 신청 가능합니다.']
    ]
  };

  // 4. 각 템플릿을 기반으로 ~5000개 질문 생성
  var allQuestions = [];
  var questionIndex = 1;
  var catIds = Object.keys(qTemplates);
  var names = ['김*수','이*진','박*현','최*아','정*호','강*미','조*원','한*정','윤*석','서*리',
               '임*빈','나*우','류*은','신*혁','장*희','오*준','배*영','허*연','문*찬','송*라',
               '홍*태','백*솔','안*민','유*지','구*훈','양*서','노*율','전*경','황*담','차*윤',
               '곽*영','하*름','민*기','권*나','표*진','남*아','도*현','심*율','성*빈','원*서'];

  var targetTotal = 5000;
  var totalTemplates = 0;
  catIds.forEach(function(cid) { totalTemplates += qTemplates[cid].length; });

  // 각 카테고리당 반복 배수 계산
  var multiplier = Math.ceil(targetTotal / totalTemplates);

  catIds.forEach(function(catId) {
    var templates = qTemplates[catId];
    for (var round = 0; round < multiplier; round++) {
      templates.forEach(function(tpl) {
        if (questionIndex > targetTotal) return;
        var suffix = round > 0 ? ' (' + (round+1) + ')' : '';
        var clickCount = Math.floor(Math.random() * 800) + 10;
        var daysAgo = Math.floor(Math.random() * 90);
        var date = new Date();
        date.setDate(date.getDate() - daysAgo);

        allQuestions.push({
          question_id: 'Q_' + String(questionIndex).padStart(5, '0'),
          product_id: 'PROD_001',
          category_id: catId,
          question_text: tpl[0] + suffix,
          answer_text: tpl[1],
          author_name: names[questionIndex % names.length],
          created_at: date.toISOString(),
          status: 'answered',
          click_count: clickCount,
          related_count: Math.floor(Math.random() * 40) + 3
        });
        questionIndex++;
      });
    }
  });

  // 5. 배치로 데이터 삽입 (성능 최적화)
  var sheet = getOrCreateSheet('Questions');
  var headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];

  var rows = allQuestions.map(function(q) {
    return headers.map(function(h) { return q[h] !== undefined ? q[h] : ''; });
  });

  if (rows.length > 0) {
    sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }

  // 6. ClickLog 더미 데이터 생성 (2000명 고유 회원, 각 12~18개 질문 클릭 → ~30000)
  var clickLogSheet = getOrCreateSheet('ClickLog');
  var clickHeaders = clickLogSheet.getRange(1, 1, 1, clickLogSheet.getLastColumn()).getValues()[0];

  var totalMembers = 2000;
  var clickRows = [];
  var questionIds = allQuestions.map(function(q) { return q.question_id; });

  for (var m = 1; m <= totalMembers; m++) {
    var memberId = 'MEM_' + String(m).padStart(5, '0');
    var clickCount = Math.floor(Math.random() * 7) + 12; // 12~18개 클릭
    var shuffled = questionIds.slice().sort(function() { return 0.5 - Math.random(); });
    var picked = shuffled.slice(0, Math.min(clickCount, shuffled.length));

    picked.forEach(function(qId) {
      var daysAgo = Math.floor(Math.random() * 90);
      var clickDate = new Date();
      clickDate.setDate(clickDate.getDate() - daysAgo);
      var logId = 'CL_' + Date.now() + '_' + Math.floor(Math.random() * 100000);

      var logData = {
        log_id: logId,
        question_id: qId,
        session_id: 'sess_' + memberId,
        member_id: memberId,
        clicked_at: clickDate.toISOString()
      };

      var row = clickHeaders.map(function(h) { return logData[h] !== undefined ? logData[h] : ''; });
      clickRows.push(row);
    });
  }

  if (clickRows.length > 0) {
    // 30000건 이상이면 배치로 나눠서 삽입 (Apps Script 제한 대비)
    var batchSize = 10000;
    for (var b = 0; b < clickRows.length; b += batchSize) {
      var batch = clickRows.slice(b, b + batchSize);
      var startRow = clickLogSheet.getLastRow() + 1;
      clickLogSheet.getRange(startRow, 1, batch.length, clickHeaders.length).setValues(batch);
    }
  }

  Logger.log('샘플 데이터 투입 완료! Products: 1, Categories: ' + categories.length + ', Questions: ' + allQuestions.length + ', ClickLogs: ' + clickRows.length);
}

/**
 * 기존 Questions 데이터를 유지하면서 ClickLog만 생성
 * 스프레드시트에 이미 질문 데이터가 있을 때 사용
 *
 * - 기존 ClickLog를 지우고 새로 생성
 * - 500명의 가상 멤버가 각 10~20개 질문 클릭
 * - 총 약 5,000~10,000개 ClickLog 행 생성
 */
function seedClickLog() {
  // 기존 ClickLog 클리어
  clearSheetData('ClickLog');

  // 기존 Questions에서 question_id 목록 읽기
  var questionsSheet = getOrCreateSheet('Questions');
  var qData = questionsSheet.getDataRange().getValues();
  if (qData.length <= 1) {
    Logger.log('Questions 시트에 데이터가 없습니다. seedDemoData()를 먼저 실행해주세요.');
    return;
  }

  var headers = qData[0];
  var qIdIndex = headers.indexOf('question_id');
  var catIdIndex = headers.indexOf('category_id');
  if (qIdIndex === -1) {
    Logger.log('question_id 컬럼을 찾을 수 없습니다.');
    return;
  }

  var questionIds = [];
  for (var i = 1; i < qData.length; i++) {
    var qId = qData[i][qIdIndex];
    if (qId) questionIds.push(String(qId));
  }

  Logger.log('기존 질문 수: ' + questionIds.length);

  // ClickLog 시트 준비
  var clickLogSheet = getOrCreateSheet('ClickLog');
  var clickHeaders = clickLogSheet.getRange(1, 1, 1, clickLogSheet.getLastColumn()).getValues()[0];

  // 500명 가상 멤버, 각 10~20개 질문 클릭
  var totalMembers = 500;
  var clickRows = [];

  for (var m = 1; m <= totalMembers; m++) {
    var memberId = 'MEM_' + String(m).padStart(5, '0');
    var clickCount = Math.floor(Math.random() * 11) + 10; // 10~20개 클릭

    // 랜덤하게 질문 선택 (중복 없이)
    var shuffled = questionIds.slice().sort(function() { return 0.5 - Math.random(); });
    var picked = shuffled.slice(0, Math.min(clickCount, shuffled.length));

    picked.forEach(function(qId) {
      var daysAgo = Math.floor(Math.random() * 90);
      var clickDate = new Date();
      clickDate.setDate(clickDate.getDate() - daysAgo);
      var hours = Math.floor(Math.random() * 24);
      var mins = Math.floor(Math.random() * 60);
      clickDate.setHours(hours, mins);

      var logId = 'CL_' + Date.now() + '_' + Math.floor(Math.random() * 100000);

      var logData = {
        log_id: logId,
        question_id: qId,
        session_id: 'sess_' + memberId,
        member_id: memberId,
        clicked_at: clickDate.toISOString()
      };

      var row = clickHeaders.map(function(h) { return logData[h] !== undefined ? logData[h] : ''; });
      clickRows.push(row);
    });
  }

  // 배치로 삽입
  if (clickRows.length > 0) {
    var batchSize = 10000;
    for (var b = 0; b < clickRows.length; b += batchSize) {
      var batch = clickRows.slice(b, b + batchSize);
      var startRow = clickLogSheet.getLastRow() + 1;
      clickLogSheet.getRange(startRow, 1, batch.length, clickHeaders.length).setValues(batch);
    }
  }

  Logger.log('ClickLog 생성 완료! 멤버: ' + totalMembers + '명, 총 클릭 로그: ' + clickRows.length + '건, 대상 질문: ' + questionIds.length + '개');
}

/**
 * 시트 데이터 클리어 (헤더는 유지)
 */
function clearSheetData(sheetName) {
  var sheet = getOrCreateSheet(sheetName);
  var lastRow = sheet.getLastRow();
  if (lastRow > 1) {
    sheet.deleteRows(2, lastRow - 1);
  }
}
