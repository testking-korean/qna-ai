      '국내 자체 공장에서 생산됩니다.',
      '자사 브랜드 정품입니다.',
      '구매일로부터 1년간 품질보증됩니다.'
    ]
  };

  // 작성자 이름 풀
  var authors = [
    '김*수', '이*영', '박*진', '최*호', '정*은', '강*민', '조*현', '윤*서',
    '장*우', '임*아', '한*기', '오*연', '서*준', '신*혜', '권*식', '황*정',
    '안*빈', '송*원', '전*리', '홍*택', '유*나', '고*성', '문*희', '양*규',
    '배*솔', '백*훈', '허*미', '남*환', '심*진', '노*경', '하*율', '곽*지'
  ];

  var typeNames = Object.keys(typeMap);
  var rows = [];

  for (var i = 1; i <= 500; i++) {
    // 랜덤 유형 선택
    var typeName = typeNames[Math.floor(Math.random() * typeNames.length)];
    var subTypes = typeMap[typeName];
    var subTypeName = subTypes[Math.floor(Math.random() * subTypes.length)];

    // 해당 유형의 질문/답변 템플릿에서 선택
    var qTemplates = questionTemplates[typeName];
    var aTemplates = answerTemplates[typeName];
    var qIdx = Math.floor(Math.random() * qTemplates.length);

    var questionText = qTemplates[qIdx];
    var answerText = aTemplates[qIdx];

    // 랜덤 메타데이터
    var author = authors[Math.floor(Math.random() * authors.length)];
    var daysAgo = Math.floor(Math.random() * 180);
    var date = new Date();
    date.setDate(date.getDate() - daysAgo);
    var dateStr = date.toISOString().split('T')[0];

    var status = Math.random() < 0.85 ? 'answered' : 'pending';
    if (status === 'pending') answerText = '';

    var clickCount = Math.floor(Math.random() * 500);
    var relatedCount = Math.floor(Math.random() * 15) + 1;
    var questionId = 'Q_' + String(i).padStart(4, '0');

    var rowData = {
      '질문ID': questionId,
      '제품ID': 'PROD_001',
      '질문유형': typeName,
      '질문세부유형': subTypeName,
      '대표질문그룹': '',
      '질문내용': questionText,
      '답변내용': answerText,
      '작성자': author,
      '작성일': dateStr,
      '상태': status,
      '클릭수': clickCount,
      '관련질문수': relatedCount
    };

    var row = headers.map(function(h) { return rowData[h] !== undefined ? rowData[h] : ''; });
    rows.push(row);
  }

  // 배치 삽입
  if (rows.length > 0) {
    sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }

  // Products 시트에 PROD_001 등록 (없으면)
  var productsSheet = getOrCreateSheet('Products');
  var pData = productsSheet.getDataRange().getValues();
  var hasProd = false;
  for (var p = 1; p < pData.length; p++) {
    if (String(pData[p][0]) === 'PROD_001') { hasProd = true; break; }
  }
  if (!hasProd) {
    productsSheet.appendRow(['PROD_001', '프리미엄 코튼 맨투맨', 'SELLER_001', new Date().toISOString().split('T')[0]]);
  }

  Logger.log('Questions 시드 완료! 총 ' + rows.length + '개 질문 생성');
}

/**
 * 시트 데이터 클리어 (헤더는 유지)
 */
function clearSheetData(sheetName) {
  var sheet = getOrCreateSheet(sheetName);
  var lastRow = sheet.getLastRow();
  if (lastRow > 1) {
    sheet.deleteRows(2, lastRow - 1);
  }
}
